{
  "manifest_version": 3,
  "name": "Reality Check AI",
  "version": "1.0",
  "description": "Real-time AI image detection on social media",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "windows",
    "tabCapture"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "*://*.instagram.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.linkedin.com/*",
    "*://*.reddit.com/*",
    "*://*.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": [
      "*://*.facebook.com/*",
      "*://*.instagram.com/*",
      "*://*.twitter.com/*",
      "*://*.x.com/*",
      "*://*.linkedin.com/*",
      "*://*.reddit.com/*",
      "*://*.tiktok.com/*"
    ],
    "js": ["content.js"],
    "css": ["overlay.css"]
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [{
    "resources": ["dashboard/*", "onboarding.html"],
    "matches": ["<all_urls>"]
  }]
}